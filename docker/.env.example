# docker/.env — usato da docker compose build (--env-file) e deploy-frontend.sh
# Copiare in docker/.env. NON committare docker/.env reale.

# =============================================================================
# PROD — esempio (rebuild obbligatorio dopo ogni modifica)
# =============================================================================
NUXT_SITE_URL=https://iartnet.it
NUXT_PUBLIC_SITE_URL=https://iartnet.it
NUXT_PUBLIC_BASE_URL=https://cms.iartnet.it
NUXT_PUBLIC_BASE_DATA_URL=https://ingestion.iartnet.it
NUXT_PUBLIC_BASEIIIF_URL=https://iiif.iartnet.it

NUXT_PUBLIC_WAI_ENABLED=true
NUXT_PUBLIC_WAI_SITE_ID=46689
NUXT_PUBLIC_WAI_TRACKER_URL=https://ingestion.webanalytics.italia.it/
NUXT_PUBLIC_WAI_DOMAINS=iartnet.it,www.iartnet.it

NUXT_PUBLIC_SITEMAP_ENABLED=true

# =============================================================================
# STG — esempio (sostituire host sopra con questi su ambiente staging)
# =============================================================================
# NUXT_SITE_URL=https://iartnet.gpams.it
# NUXT_PUBLIC_SITE_URL=https://iartnet.gpams.it
# NUXT_PUBLIC_BASE_URL=https://cms.gpams.it
# NUXT_PUBLIC_BASE_DATA_URL=https://ingestion.gpams.it
# NUXT_PUBLIC_BASEIIIF_URL=https://iiif.gpams.it
# NUXT_PUBLIC_WAI_ENABLED=false
# NUXT_PUBLIC_SITEMAP_ENABLED=false
