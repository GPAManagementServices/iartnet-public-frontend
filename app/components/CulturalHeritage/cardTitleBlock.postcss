/* Stili del blocco titolo (CulturalHeritageTitleBlock) dentro h3.card-title. */
.card-title {
  :deep(.card-title-stack) {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
  }

  :deep(.card-title-line--meta) {
    font-size: var(--text-small);
    color: var(--gray-8);
    font-weight: 400;
    line-height: 1.3;
  }
}
