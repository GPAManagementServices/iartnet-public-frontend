# =============================================================================
# Nuxt public / site URLs — READ CAREFULLY (build-time vs runtime)
# =============================================================================
#
# Le chiavi NUXT_PUBLIC_* e NUXT_SITE_URL devono essere disponibili durante
# `pnpm build` / `docker build` (fase build del Dockerfile), altrimenti nel
# bundle (.output / Nitro) restano i default di nuxt.config.ts.
#
# docker/compose.yaml passa queste variabili come build.args leggendo docker/.env
# (--env-file nei deploy script). Il solo env_file sul container runtime NON
# rigenera il bundle se l’immagine è stata buildata senza gli stessi valori.
#
# L’immagine CI su main bake-a host STG (*.gpams.it): non promuoverla in PROD
# senza rebuild con env PROD (vedi docker/.env.example).
#
# =============================================================================

# URL pubblico del sito (canonical, OG, JSON-LD, i18n baseUrl).
NUXT_SITE_URL=https://iartnet.xxx.zz
NUXT_PUBLIC_SITE_URL=https://iartnet.xxx.zz

NUXT_PUBLIC_BASE_URL=https://cms.xxx.zz
NUXT_PUBLIC_BASEIIIF_URL=https://iiif.xxx.zz
NUXT_PUBLIC_BASE_DATA_URL=https://ingestion.xxx.zz

NUXT_PUBLIC_SHOW_HIDDEN_DATA=true
NUXT_PUBLIC_APP_VERSION='d.d.d-dev'

# Web Analytics Italia — default spento; abilitare solo in PROD (app/plugins/wai.client.ts).
NUXT_PUBLIC_WAI_ENABLED=false
NUXT_PUBLIC_WAI_SITE_ID=
NUXT_PUBLIC_WAI_TRACKER_URL=https://ingestion.webanalytics.italia.it/
NUXT_PUBLIC_WAI_DOMAINS=

# Sitemap SEO (@nuxtjs/seo) — default spento; abilitare solo in PROD.
NUXT_PUBLIC_SITEMAP_ENABLED=false

# --- PROD (docker/.env sul server PROD, poi rebuild immagine) ---
# NUXT_SITE_URL=https://iartnet.it
# NUXT_PUBLIC_SITE_URL=https://iartnet.it
# NUXT_PUBLIC_BASE_URL=https://cms.iartnet.it
# NUXT_PUBLIC_BASE_DATA_URL=https://ingestion.iartnet.it
# NUXT_PUBLIC_BASEIIIF_URL=https://iiif.iartnet.it
# NUXT_PUBLIC_WAI_ENABLED=true
# NUXT_PUBLIC_WAI_SITE_ID=46689
# NUXT_PUBLIC_WAI_DOMAINS=iartnet.it,www.iartnet.it
# NUXT_PUBLIC_SITEMAP_ENABLED=true

# --- STG ---
# NUXT_SITE_URL=https://iartnet.gpams.it
# NUXT_PUBLIC_BASE_URL=https://cms.gpams.it
# NUXT_PUBLIC_BASE_DATA_URL=https://ingestion.gpams.it
# NUXT_PUBLIC_WAI_ENABLED=false
# NUXT_PUBLIC_SITEMAP_ENABLED=false
